@pytest.mark.polarion("{{POLARION_ID}}")
class Test{{FeatureClassName}}Connectivity:
    """
    Tests for {{FEATURE_NAME}} localnet connectivity.

    Markers:
        - {{TIER}}
        - {{PRIORITY}}
        {{ADDITIONAL_MARKERS}}

    Preconditions:
        - NNCP for localnet bridge mappings configured
        - Localnet CUDN created
        - VMs running with localnet interfaces and static IPs
    """

    def test_{{feature}}_ipv4_connectivity(self, running_{{feature}}_vms):
        """
        Test that IPv4 connectivity works on localnet.

        Steps:
            Execute ping from VM-A to VM-B using IPv4

        Expected:
            - Ping succeeds with 0% packet loss
        """
        vm_a, vm_b = running_{{feature}}_vms
        vm_b_ip = lookup_iface_status(vm=vm_b, iface_name=LOCALNET_INTERFACE_NAME)[IP_ADDRESS]
        LOGGER.info(f"Testing IPv4 connectivity from {vm_a.name} to {vm_b.name} ({vm_b_ip})")
        assert_ping_successful(src_vm=vm_a, dst_ip=vm_b_ip)

    {{ADDITIONAL_TESTS}}
