@pytest.fixture(scope="module")
def nncp_localnet_{{feature}}(nmstate_dependent_placeholder, admin_client):
    """
    NNCP for {{FEATURE_NAME}} localnet bridge mappings.

    Yields:
        NodeNetworkConfigurationPolicy: NNCP resource
    """
    desired_state = libnncp.DesiredState(
        ovn=libnncp.OVN([
            libnncp.BridgeMappings(
                localnet="{{PHYSICAL_NETWORK_NAME}}",
                bridge=libnncp.DEFAULT_OVN_EXTERNAL_BRIDGE,
                state=libnncp.BridgeMappings.State.PRESENT.value,
            )
        ])
    )

    with libnncp.NodeNetworkConfigurationPolicy(
        client=admin_client,
        name="{{feature}}-localnet-nncp",
        desired_state=desired_state,
        node_selector={WORKER_NODE_LABEL_KEY: ""},
    ) as nncp:
        nncp.wait_for_status_success()
        LOGGER.info(f"NNCP {nncp.name} configured successfully")
        yield nncp


@pytest.fixture(scope="class")
def localnet_cudn_{{feature}}(admin_client, nncp_localnet_{{feature}}, namespace):
    """
    Localnet CUDN for {{FEATURE_NAME}}.

    Requires nncp_localnet_{{feature}} fixture to set up bridge mappings first.

    Yields:
        ClusterUserDefinedNetwork: Localnet CUDN resource
    """
    # Add required label to namespace for CUDN namespace selector
    from ocp_resources.namespace import Namespace
    from ocp_resources.resource import ResourceEditor
    admin_ns = Namespace(client=admin_client, name=namespace.name, ensure_exists=True)
    ResourceEditor({admin_ns: {"metadata": {"labels": {"{{feature}}": "test"}}}}).update()

    with localnet_cudn(
        name=LOCALNET_INTERFACE_NAME,
        match_labels={"{{feature}}": "test"},
        physical_network_name="{{PHYSICAL_NETWORK_NAME}}",
        vlan_id={{VLAN_ID}},
        client=admin_client,
    ) as cudn:
        cudn.wait_for_status_success()
        LOGGER.info(f"Localnet CUDN {cudn.name} created")
        yield cudn


